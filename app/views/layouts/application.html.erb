<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "シフト管理" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="シフト管理">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <%# ナビゲーションバー %>
    <% if user_signed_in? %>
      <nav class="bg-blue-700 text-white shadow-md sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4">
          <div class="flex items-center justify-between h-14">
            <%# ロゴ・アプリ名 %>
            <%= link_to root_path, class: "text-lg font-bold tracking-wide" do %>
              <span>&#128197; シフト管理</span>
            <% end %>

            <%# デスクトップ用メニュー %>
            <div class="hidden md:flex items-center gap-6 text-sm font-medium">
              <%= link_to "ダッシュボード", root_path, class: "hover:text-blue-200 transition" %>
              <%= link_to "現場", sites_path, class: "hover:text-blue-200 transition" %>
              <%= link_to "社員", employees_path, class: "hover:text-blue-200 transition" %>
              <%= link_to "配置", assignments_path, class: "hover:text-blue-200 transition" %>
              <%= link_to "カレンダー", calendar_assignments_path, class: "hover:text-blue-200 transition" %>
              <% if current_employee %>
                <%= link_to "自分の配置", employee_path(current_employee), class: "hover:text-blue-200 transition" %>
              <% end %>
              <span class="text-blue-300">|</span>
              <%= link_to current_user.email, edit_user_registration_path, class: "text-blue-200 text-xs hover:text-white hover:underline" %>
              <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "bg-blue-500 hover:bg-blue-400 px-3 py-1 rounded transition" %>
            </div>

            <%# モバイル用ハンバーガーボタン %>
            <button id="menu-btn" class="md:hidden p-2 rounded hover:bg-blue-600 focus:outline-none">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>

        <%# モバイル用ドロップダウンメニュー %>
        <div id="mobile-menu" class="md:hidden hidden border-t border-blue-600">
          <div class="px-4 py-3 space-y-2 text-sm font-medium">
            <%= link_to "ダッシュボード", root_path, class: "block py-2 hover:text-blue-200" %>
            <%= link_to "現場管理", sites_path, class: "block py-2 hover:text-blue-200" %>
            <%= link_to "社員管理", employees_path, class: "block py-2 hover:text-blue-200" %>
            <%= link_to "配置管理", assignments_path, class: "block py-2 hover:text-blue-200" %>
            <%= link_to "カレンダー", calendar_assignments_path, class: "block py-2 hover:text-blue-200" %>
            <% if current_employee %>
              <%= link_to "自分の配置", employee_path(current_employee), class: "block py-2 hover:text-blue-200" %>
            <% end %>
            <div class="pt-2 border-t border-blue-600">
              <%= link_to "アカウント設定（#{current_user.email}）", edit_user_registration_path, class: "block py-2 text-blue-200 hover:text-white" %>
              <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "block py-2 text-blue-200 hover:text-white" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <%# フラッシュメッセージ %>
    <div class="max-w-5xl mx-auto px-4 mt-4">
      <% if notice %>
        <div class="bg-green-100 border border-green-400 text-green-800 px-4 py-3 rounded mb-4" role="alert">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-100 border border-red-400 text-red-800 px-4 py-3 rounded mb-4" role="alert">
          <%= alert %>
        </div>
      <% end %>
    </div>

    <%# メインコンテンツ（カレンダーなど横幅が必要なページはfull_widthフラグで制御） %>
    <main class="<%= content_for?(:full_width) ? 'pb-10' : 'max-w-5xl mx-auto px-4 pb-10' %>">
      <%= yield %>
    </main>

    <%# モバイルメニュートグルのスクリプト %>
    <script>
      document.getElementById('menu-btn')?.addEventListener('click', function() {
        document.getElementById('mobile-menu').classList.toggle('hidden');
      });
    </script>
  </body>
</html>
