<%- if controller_name != 'sessions' %>
  <p><%= link_to "ログインはこちら", new_session_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "アカウント登録はこちら", new_registration_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p><%= link_to "パスワードをお忘れの方", new_password_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "確認メールが届いていない方", new_confirmation_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "アカウントのロック解除", new_unlock_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>
