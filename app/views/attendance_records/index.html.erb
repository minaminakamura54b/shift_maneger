<% content_for :title, "勤怠 - シフト管理" %>

<%
  wdays = %w[日 月 火 水 木 金 土]
%>

<div class="py-6">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">勤怠</h1>

  <%# 出退勤ボタン %>
  <div class="bg-white rounded-xl shadow p-6 mb-6 text-center">
    <% if @open_record %>
      <p class="text-sm text-gray-500 mb-1">出勤中</p>
      <p class="text-2xl font-bold text-gray-800 mb-4">
        <%= @open_record.clocked_in_at.strftime("%-H:%M") %> に出勤
      </p>
      <%= button_to "退勤する", clock_out_attendance_records_path, method: :post,
            class: "w-full bg-red-600 hover:bg-red-500 text-white font-bold text-lg py-4 rounded-lg transition cursor-pointer" %>
    <% else %>
      <p class="text-sm text-gray-500 mb-4">まだ出勤していません</p>
      <%= button_to "出勤する", clock_in_attendance_records_path, method: :post,
            class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-bold text-lg py-4 rounded-lg transition cursor-pointer" %>
    <% end %>
  </div>

  <%# 打刻履歴 %>
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">打刻履歴</h2>
    <% if @records.any? %>
      <ul class="divide-y divide-gray-100">
        <% @records.each do |record| %>
          <li class="py-3 flex items-center justify-between gap-2">
            <div>
              <p class="text-sm font-medium text-gray-800">
                <%= record.clocked_in_at.strftime("%Y/%m/%d") %>（<%= wdays[record.clocked_in_at.wday] %>）
              </p>
              <p class="text-xs text-gray-500">
                <%= record.clocked_in_at.strftime("%-H:%M") %>
                〜
                <%= record.clocked_out_at&.strftime("%-H:%M") || "勤務中" %>
              </p>
            </div>
            <% if (duration = record.worked_duration) %>
              <span class="text-sm text-gray-600 whitespace-nowrap">
                <%= format_duration(duration) %>
              </span>
            <% else %>
              <span class="text-xs bg-blue-100 text-blue-700 font-medium px-2 py-1 rounded-full whitespace-nowrap">勤務中</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-400 text-center py-4">打刻履歴がありません</p>
    <% end %>
  </div>
</div>
