<% content_for :title, "勤怠記録の編集 - シフト管理" %>

<div class="py-6 max-w-lg">
  <nav class="text-sm text-gray-500 mb-4">
    <%= link_to "勤怠管理", all_attendance_records_path, class: "hover:underline" %>
    <span class="mx-2">/</span>
    <span class="text-gray-800">編集</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">勤怠記録の編集</h1>

  <div class="bg-white rounded-xl shadow p-6">
    <p class="text-sm text-gray-500 mb-4">
      社員: <span class="font-medium text-gray-800"><%= @attendance_record.employee.name %></span>
    </p>

    <%= form_with model: @attendance_record, class: "space-y-5" do |f| %>
      <% if @attendance_record.errors.any? %>
        <div class="bg-red-50 border border-red-300 rounded-lg p-4">
          <p class="text-sm font-medium text-red-800 mb-2"><%= @attendance_record.errors.count %>件のエラーがあります</p>
          <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
            <% @attendance_record.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :clocked_in_at, "出勤時刻", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%# step: 1 を付けないと分単位に丸められ、出退勤が1分未満の記録では
            保存しただけで「退勤時刻が出勤時刻と同じ（＝以降ではない）」扱いになり
            バリデーションエラーになってしまうため、秒単位まで保持できるようにする %>
        <%= f.datetime_field :clocked_in_at, step: 1, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :clocked_out_at, "退勤時刻", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.datetime_field :clocked_out_at, step: 1, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        <p class="text-xs text-gray-400 mt-1">未退勤にする場合は空欄のままにしてください</p>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "保存する", class: "bg-blue-600 hover:bg-blue-500 text-white font-medium text-sm px-6 py-2 rounded-lg transition cursor-pointer" %>
        <%= link_to "キャンセル", all_attendance_records_path, class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium text-sm px-6 py-2 rounded-lg transition" %>
      </div>
    <% end %>
  </div>
</div>
