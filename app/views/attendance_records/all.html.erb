<% content_for :title, "勤怠管理（全社員） - シフト管理" %>

<%
  wdays = %w[日 月 火 水 木 金 土]
%>

<div class="py-6">
  <div class="flex items-center justify-between mb-6 gap-2">
    <h1 class="text-2xl font-bold text-gray-800">勤怠管理</h1>
    <%= link_to "自分の勤怠", attendance_records_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <%# 社員での絞り込み %>
  <%= form_with url: all_attendance_records_path, method: :get, class: "mb-6" do %>
    <%= select_tag :employee_id,
          options_for_select([ [ "全社員", "" ] ] + @employees.map { |e| [ e.name, e.id ] }, @employee_id),
          onchange: "this.form.requestSubmit()",
          class: "text-sm border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" %>
  <% end %>

  <% if @grouped_records.any? %>
    <%# データが多いとフラットな一覧では読みにくいため、社員ごとにグループ化して表示する %>
    <div class="space-y-4">
      <% @grouped_records.each do |employee, records| %>
        <% total_seconds = records.filter_map(&:worked_duration).sum %>
        <div class="bg-white rounded-xl shadow overflow-hidden">
          <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex items-center justify-between gap-2">
            <h2 class="font-semibold text-gray-800"><%= employee.name %></h2>
            <div class="text-xs text-gray-500 whitespace-nowrap">
              <%= records.size %>件
              <% if total_seconds > 0 %>
                ／ 合計<%= format_duration(total_seconds) %>
              <% end %>
            </div>
          </div>
          <ul class="divide-y divide-gray-100">
            <% records.each do |record| %>
              <li class="px-4 py-3 flex items-center justify-between gap-2">
                <div>
                  <p class="text-sm text-gray-800">
                    <%= record.clocked_in_at.strftime("%Y/%m/%d") %>（<%= wdays[record.clocked_in_at.wday] %>）
                  </p>
                  <p class="text-xs text-gray-500 mt-0.5">
                    <%= record.clocked_in_at.strftime("%-H:%M") %>
                    〜
                    <%= record.clocked_out_at&.strftime("%-H:%M") || "―" %>
                  </p>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <% if record.clocked_out_at.nil? %>
                    <span class="text-xs bg-blue-100 text-blue-700 font-medium px-2 py-1 rounded-full whitespace-nowrap">勤務中</span>
                  <% else %>
                    <span class="text-xs text-gray-500 whitespace-nowrap"><%= format_duration(record.worked_duration) %></span>
                  <% end %>
                  <%= link_to "編集", edit_attendance_record_path(record), class: "text-sm text-blue-600 hover:underline whitespace-nowrap" %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow p-10 text-center">
      <p class="text-4xl mb-4">&#128203;</p>
      <p class="text-gray-500">打刻記録がありません</p>
    </div>
  <% end %>
</div>
