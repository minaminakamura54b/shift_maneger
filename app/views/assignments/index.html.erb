<% content_for :title, "配置一覧 - シフト管理" %>

<div class="py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">配置一覧</h1>
    <%= link_to "＋ 新規登録", new_assignment_path, class: "bg-orange-500 hover:bg-orange-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>

  <% if @assignments.any? %>
    <%# スマホでは横に情報を詰め込んだ表だと現場名などが折り返して読みにくいため、
        現場一覧と同じカード形式で表示する %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @assignments.each do |assignment| %>
        <div class="bg-white rounded-xl shadow hover:shadow-md transition">
          <%= link_to assignment, class: "block p-4" do %>
            <div class="flex items-start justify-between gap-2 mb-2">
              <span class="font-medium text-gray-800"><%= assignment.employee.name %></span>
              <span class="text-xs text-gray-400 whitespace-nowrap"><%= assignment.start_date&.strftime("%Y/%m/%d") %></span>
            </div>
            <p class="text-sm text-gray-600"><%= assignment.display_site_name %></p>
            <% if assignment.end_date %>
              <p class="text-xs text-gray-400 mt-1">〜 <%= assignment.end_date.strftime("%Y/%m/%d") %></p>
            <% end %>
          <% end %>
          <% if can_manage_assignment?(assignment) %>
            <div class="border-t border-gray-100 px-4 py-2 flex gap-3">
              <%= link_to "編集", edit_assignment_path(assignment), class: "text-sm text-blue-600 hover:underline" %>
              <%= link_to "削除", assignment, data: { turbo_method: :delete, turbo_confirm: "この配置を削除してもよいですか？" }, class: "text-sm text-red-500 hover:underline" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow p-10 text-center">
      <p class="text-4xl mb-4">&#128203;</p>
      <p class="text-gray-500 mb-4">配置がまだ登録されていません</p>
      <%= link_to "最初の配置を登録する", new_assignment_path, class: "bg-orange-500 hover:bg-orange-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
    </div>
  <% end %>
</div>
