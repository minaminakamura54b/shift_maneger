<% content_for :title, "配置一覧 - シフト管理" %>

<div class="py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">配置一覧</h1>
    <%= link_to "＋ 新規登録", new_assignment_path, class: "bg-orange-500 hover:bg-orange-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>

  <% if @assignments.any? %>
    <div class="bg-white rounded-xl shadow overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-500">社員名</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500">現場名</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500 hidden sm:table-cell">開始日</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500 hidden md:table-cell">終了日</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @assignments.each do |assignment| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-3 font-medium text-gray-800">
                <%= link_to assignment.employee.name, assignment.employee, class: "hover:text-green-600" %>
              </td>
              <td class="px-4 py-3 text-gray-600">
                <% if assignment.site %>
                  <%= link_to assignment.display_site_name, assignment.site, class: "hover:text-blue-600" %>
                <% else %>
                  <%= assignment.display_site_name %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-gray-600 hidden sm:table-cell"><%= assignment.start_date&.strftime("%Y/%m/%d") %></td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell"><%= assignment.end_date&.strftime("%Y/%m/%d") || "—" %></td>
              <td class="px-4 py-3 flex gap-3">
                <% if can_manage_assignment?(assignment) %>
                  <%= link_to "編集", edit_assignment_path(assignment), class: "text-blue-600 hover:underline" %>
                  <%= link_to "削除", assignment, data: { turbo_method: :delete, turbo_confirm: "この配置を削除してもよいですか？" }, class: "text-red-500 hover:underline" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow p-10 text-center">
      <p class="text-4xl mb-4">&#128203;</p>
      <p class="text-gray-500 mb-4">配置がまだ登録されていません</p>
      <%= link_to "最初の配置を登録する", new_assignment_path, class: "bg-orange-500 hover:bg-orange-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
    </div>
  <% end %>
</div>
