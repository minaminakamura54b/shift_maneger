<% content_for :title, "#{@employee.name} - シフト管理" %>

<div class="py-6">
  <nav class="text-sm text-gray-500 mb-4">
    <%= link_to "社員一覧", employees_path, class: "hover:underline" %>
    <span class="mx-2">/</span>
    <span class="text-gray-800"><%= @employee.name %></span>
  </nav>

  <div class="bg-white rounded-xl shadow p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="shrink-0 bg-green-100 text-green-600 rounded-full w-14 h-14 flex items-center justify-center text-2xl font-bold">
          <%= @employee.name[0] %>
        </div>
        <div class="min-w-0">
          <h1 class="text-2xl font-bold text-gray-800 truncate"><%= @employee.name %></h1>
          <p class="text-gray-500 text-sm truncate"><%= @employee.email %></p>
        </div>
      </div>
      <% if can_manage_employee?(@employee) %>
        <div class="flex gap-2 shrink-0">
          <%= link_to "編集", edit_employee_path(@employee), class: "bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-3 py-2 rounded-lg transition whitespace-nowrap" %>
          <%= link_to "削除", @employee, data: { turbo_method: :delete, turbo_confirm: "「#{@employee.name}」を削除してもよいですか？" }, class: "bg-red-100 hover:bg-red-200 text-red-700 text-sm font-medium px-3 py-2 rounded-lg transition whitespace-nowrap" %>
        </div>
      <% end %>
    </div>
    <div class="text-sm">
      <p class="text-gray-400 text-xs mb-1">電話番号</p>
      <p class="font-medium text-gray-800"><%= @employee.phone.presence || "未登録" %></p>
    </div>
  </div>

  <%# この社員の配置履歴 %>
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">配置履歴</h2>
    <% if @assignments.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-2 pr-3 font-medium text-gray-500">現場名</th>
              <th class="text-left py-2 pr-3 font-medium text-gray-500">開始日</th>
              <th class="text-left py-2 pr-3 font-medium text-gray-500">終了日</th>
              <th class="text-left py-2 font-medium text-gray-500"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @assignments.each do |assignment| %>
              <tr class="hover:bg-gray-50">
                <td class="py-3 pr-3 font-medium text-gray-800"><%= assignment.display_site_name %></td>
                <td class="py-3 pr-3 text-gray-600 whitespace-nowrap"><%= assignment.start_date&.strftime("%Y/%m/%d") %></td>
                <td class="py-3 pr-3 text-gray-600 whitespace-nowrap"><%= assignment.end_date&.strftime("%Y/%m/%d") || "—" %></td>
                <td class="py-3">
                  <%= link_to "詳細", assignment, class: "text-blue-600 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 text-center py-4">配置履歴がありません</p>
    <% end %>
  </div>
</div>
