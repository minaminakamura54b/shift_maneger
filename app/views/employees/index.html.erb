<% content_for :title, "社員一覧 - シフト管理" %>

<div class="py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">社員一覧</h1>
    <%= link_to "＋ 新規登録", new_employee_path, class: "bg-green-600 hover:bg-green-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>

  <% if @employees.any? %>
    <div class="bg-white rounded-xl shadow overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-500">名前</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500 hidden sm:table-cell">メールアドレス</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500 hidden md:table-cell">電話番号</th>
            <th class="text-left px-4 py-3 font-medium text-gray-500">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @employees.each do |employee| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-3">
                <%= link_to employee.name, employee, class: "font-medium text-gray-800 hover:text-blue-600" %>
              </td>
              <td class="px-4 py-3 text-gray-600 hidden sm:table-cell"><%= employee.email %></td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell"><%= employee.phone.presence || "—" %></td>
              <td class="px-4 py-3 flex gap-3">
                <%= link_to "編集", edit_employee_path(employee), class: "text-blue-600 hover:underline" %>
                <%= link_to "削除", employee, data: { turbo_method: :delete, turbo_confirm: "「#{employee.name}」を削除してもよいですか？" }, class: "text-red-500 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow p-10 text-center">
      <p class="text-4xl mb-4">&#128100;</p>
      <p class="text-gray-500 mb-4">社員がまだ登録されていません</p>
      <%= link_to "最初の社員を登録する", new_employee_path, class: "bg-green-600 hover:bg-green-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
    </div>
  <% end %>
</div>
