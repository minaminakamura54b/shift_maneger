<% content_for :title, "現場一覧 - シフト管理" %>

<div class="py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">現場一覧</h1>
    <%= link_to "＋ 新規登録", new_site_path, class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>

  <% if @sites.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      <% @sites.each do |site| %>
        <div class="bg-white rounded-xl shadow hover:shadow-md transition">
          <%= link_to site, class: "block p-4" do %>
            <div class="flex items-start justify-between gap-2 mb-2">
              <h2 class="text-lg font-bold text-gray-800"><%= site.name %></h2>
              <span class="shrink-0 text-xs bg-blue-100 text-blue-700 font-medium px-2 py-1 rounded-full whitespace-nowrap">
                <%= site.start_date&.strftime("%Y/%m/%d") %>
              </span>
            </div>
            <p class="text-sm text-gray-500"><%= site.address.presence || "住所未登録" %></p>
            <% if site.end_date %>
              <p class="text-xs text-gray-400 mt-1">〜 <%= site.end_date.strftime("%Y/%m/%d") %></p>
            <% end %>
          <% end %>
          <div class="border-t border-gray-100 px-4 py-2 flex gap-3">
            <%= link_to "編集", edit_site_path(site), class: "text-sm text-blue-600 hover:underline" %>
            <%= link_to "削除", site, data: { turbo_method: :delete, turbo_confirm: "「#{site.name}」を削除してもよいですか？" }, class: "text-sm text-red-500 hover:underline" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl shadow p-10 text-center">
      <p class="text-4xl mb-4">&#127970;</p>
      <p class="text-gray-500 mb-4">現場がまだ登録されていません</p>
      <%= link_to "最初の現場を登録する", new_site_path, class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
    </div>
  <% end %>
</div>
