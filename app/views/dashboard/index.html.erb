<% content_for :title, "ダッシュボード - シフト管理" %>

<div class="py-6">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">ダッシュボード</h1>

  <%# サマリーカード（スマホでは3列に並べて縦スペースを節約） %>
  <div class="grid grid-cols-3 gap-2 sm:gap-4 mb-8">
    <%= link_to sites_path, class: "bg-white rounded-xl shadow p-3 sm:p-5 flex flex-col sm:flex-row items-center gap-1 sm:gap-4 text-center sm:text-left hover:shadow-md transition" do %>
      <div class="bg-blue-100 text-blue-600 rounded-full p-2 sm:p-3 text-base sm:text-2xl">&#127970;</div>
      <div>
        <p class="text-xs sm:text-sm text-gray-500">現場数</p>
        <p class="text-xl sm:text-3xl font-bold text-gray-800"><%= @sites_count %></p>
      </div>
    <% end %>

    <%= link_to employees_path, class: "bg-white rounded-xl shadow p-3 sm:p-5 flex flex-col sm:flex-row items-center gap-1 sm:gap-4 text-center sm:text-left hover:shadow-md transition" do %>
      <div class="bg-green-100 text-green-600 rounded-full p-2 sm:p-3 text-base sm:text-2xl">&#128100;</div>
      <div>
        <p class="text-xs sm:text-sm text-gray-500">社員数</p>
        <p class="text-xl sm:text-3xl font-bold text-gray-800"><%= @employees_count %></p>
      </div>
    <% end %>

    <%= link_to assignments_path, class: "bg-white rounded-xl shadow p-3 sm:p-5 flex flex-col sm:flex-row items-center gap-1 sm:gap-4 text-center sm:text-left hover:shadow-md transition" do %>
      <div class="bg-orange-100 text-orange-600 rounded-full p-2 sm:p-3 text-base sm:text-2xl">&#128203;</div>
      <div>
        <p class="text-xs sm:text-sm text-gray-500">配置数</p>
        <p class="text-xl sm:text-3xl font-bold text-gray-800"><%= @assignments_count %></p>
      </div>
    <% end %>
  </div>

  <%# クイックアクション %>
  <div class="bg-white rounded-xl shadow p-5 mb-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">クイック登録</h2>
    <div class="flex flex-wrap gap-3">
      <%= link_to "＋ 現場登録", new_site_path, class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
      <%= link_to "＋ 社員登録", new_employee_path, class: "bg-green-600 hover:bg-green-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
      <%= link_to "＋ 配置登録", new_assignment_path, class: "bg-orange-500 hover:bg-orange-400 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# 直近の現場 %>
    <div class="bg-white rounded-xl shadow p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">直近の現場</h2>
        <%= link_to "一覧へ", sites_path, class: "text-sm text-blue-600 hover:underline" %>
      </div>
      <% if @recent_sites.any? %>
        <ul class="divide-y divide-gray-100">
          <% @recent_sites.each do |site| %>
            <li class="py-3">
              <%= link_to site, class: "flex items-center justify-between hover:bg-gray-50 -mx-2 px-2 rounded" do %>
                <div>
                  <p class="font-medium text-gray-800 text-sm"><%= site.name %></p>
                  <p class="text-xs text-gray-500"><%= site.address %></p>
                </div>
                <span class="text-xs text-gray-400"><%= site.start_date&.strftime("%m/%d") %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-400 text-center py-4">現場がまだ登録されていません</p>
      <% end %>
    </div>

    <%# 直近の配置 %>
    <div class="bg-white rounded-xl shadow p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-700">直近の配置</h2>
        <%= link_to "一覧へ", assignments_path, class: "text-sm text-blue-600 hover:underline" %>
      </div>
      <% if @recent_assignments.any? %>
        <ul class="divide-y divide-gray-100">
          <% @recent_assignments.each do |assignment| %>
            <li class="py-3">
              <%= link_to assignment, class: "flex items-center justify-between hover:bg-gray-50 -mx-2 px-2 rounded" do %>
                <div>
                  <p class="font-medium text-gray-800 text-sm"><%= assignment.employee.name %></p>
                  <p class="text-xs text-gray-500"><%= assignment.display_site_name %></p>
                </div>
                <span class="text-xs text-gray-400"><%= assignment.start_date&.strftime("%m/%d") %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-400 text-center py-4">配置がまだ登録されていません</p>
      <% end %>
    </div>
  </div>
</div>
