# このファイルをコピーして .env を作成し、値を環境に合わせて設定してください。
# cp .env.example .env
#
# ローカル開発では config/master.key が無くても起動できます（development/test は
# Rails が secret_key_base を自動生成します）。本番相当の設定を試す場合のみ、
# 下記の値を用意してください。

# PostgreSQL 接続URL（本番・EB環境用。ローカルは config/database.yml のデフォルト設定でOK）
DATABASE_URL=postgres://user:password@localhost:5432/shift_manager_development

# Railsのセッション等の暗号化キー（credentials.yml.enc を使わない場合に設定）
SECRET_KEY_BASE=

# config/credentials.yml.enc を復号するためのキー（config/master.key の内容と同じもの）
RAILS_MASTER_KEY=

# アプリがリッスンするポート（EB/Docker環境用。ローカルはデフォルト3000のままでOK）
PORT=3000

# メール送信（Resend）のAPIキー。取得: https://resend.com/
RESEND_API_KEY=

# メール送信元アドレス（Resendで認証済みのドメインを指定。未設定時は noreply@worknests.org）
MAILER_FROM_ADDRESS=noreply@example.com

# 確認メール・パスワード再設定メール内のリンクに使うホスト名
APP_HOST=localhost:3000

# 上記リンクのスキーム（本番は https、ローカルは http）
APP_PROTOCOL=http
